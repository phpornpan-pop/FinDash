# Copy this file to .env and fill in the values from your Supabase project
# (Project Settings > API). See README.md for the full setup guide.
#
# Leave both empty to run the app with browser-only storage (localStorage) -
# no login required, but data stays on this one device/browser only.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
